<%# T34.3 FID/INP 优化：MathJax 异步加载，减少渲染阻塞 %>
<%# 合并配置脚本为一个内联块，减少网络请求 %>
<script type="text/x-mathjax-config">
window.MathJax = {
  HTML: { useCSS: true },
  "HTML-CSS": {
    preferredFont: "TeX",
    availableFonts: ["STIX","TeX"],
    linebreaks: { automatic: true },
    EqnChunk: (window.MathJax && MathJax.Hub.Browser.isMobile) ? 10 : 50
  },
  tex2jax: {
    inlineMath: [ ["$", "$"], ["\\(","\\)"] ],
    processEscapes: true,
    ignoreClass: "tex2jax_ignore|dno",
    skipTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code']
  },
  TeX: {
    equationNumbers: { autoNumber: "AMS" },
    noUndefined: { attributes: { mathcolor: "red", mathbackground: "#FFEEEE", mathsize: "90%" } },
    Macros: { href: "{}" }
  },
  messageStyle: "none",
  loader: { load: ['input/tex', 'output/chtml', 'ui/menu'] },
  startup: {
    ready: function() {
      MathJax.startup.defaultReady();
      MathJax.startup.promise.then(function() {
        // 为已存在的数学公式添加 has-jax class
        var all = MathJax.Hub.getAllJax(), i;
        for(i = 0; i < all.length; i += 1) {
          all[i].SourceElement().parentNode.className += ' has-jax';
        }
      });
    }
  }
};
</script>
<%# 异步加载 MathJax，使用 defer 避免阻塞渲染 %>
<script defer type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.5/MathJax.js?config=TeX-MML-AM_CHTML"></script>