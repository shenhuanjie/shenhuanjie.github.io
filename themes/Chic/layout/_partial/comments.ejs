<%# Utterances 评论系统 v2.0 优化版 - 社区氛围增强 %>
<%# https://utteranc.es/ %>
<% if(theme.utterances && theme.utterances.enable && is_post()){ %>
<section class="post-comments" id="comments">
    <h3 class="comments-title">
        <span class="comments-icon">💬</span>
        互动讨论
    </h3>
    <p class="comments-guide">
        欢迎留下你的见解、疑问或心得，精选评论有机会获得积分奖励哦！
    </p>
    <div class="comments-moderation-notice">
        <svg class="icon-info" viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="16" x2="12" y2="12"></line>
            <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
        <span>所有评论需经审核后公开，请勿提交敏感信息</span>
    </div>
    <div class="comments-loading">评论加载中...</div>
    <div id="utterances-container"></div>
    <div class="comments-footer">
        <p class="comments-hint">
            <svg class="icon-github" viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            使用 GitHub 账号登录评论 · <a href="https://utteranc.es" target="_blank" rel="noopener">了解 Utterances</a>
        </p>
        <p class="comments-feedback">
            发现错误或有建议？<a href="https://github.com/shenhuanjie/shenhuanjie.github.io/issues/new" target="_blank" rel="noopener">提交反馈</a>
        </p>
    </div>
</section>
<script>
    (function() {
        function createUtterancesScript() {
            var script = document.createElement('script');
            script.src = 'https://utteranc.es/client.js';
            script.setAttribute('repo', '<%= theme.utterances.repo %>');
            script.setAttribute('issue-term', '<%= theme.utterances.issue_term || "pathname" %>');
            script.setAttribute('label', '<%= theme.utterances.label || "comment" %>');
            script.setAttribute('theme', '<%= theme.utterances.theme || "github-light" %>');
            script.setAttribute('crossorigin', 'anonymous');
            script.async = true;
            return script;
        }

        // 动态切换主题时同步切换评论主题
        function getUtterancesTheme() {
            return document.body.classList.contains('dark-theme') ?
                '<%= theme.utterances.dark_theme || "github-dark" %>' :
                '<%= theme.utterances.theme || "github-light" %>';
        }

        function updateUtterancesTheme() {
            var iframe = document.querySelector('.utterances-frame');
            if (iframe) {
                var message = {
                    type: 'set-theme',
                    theme: getUtterancesTheme()
                };
                iframe.contentWindow.postMessage(message, 'https://utteranc.es');
            }
        }

        // 监听评论加载完成
        function handleUtterancesLoad() {
            var container = document.getElementById('utterances-container');
            var loading = document.querySelector('.comments-loading');
            if (container && loading) {
                loading.style.display = 'none';
                container.classList.add('loaded');
            }
        }

        // 监听主题切换
        var observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(mutation) {
                if (mutation.attributeName === 'class') {
                    updateUtterancesTheme();
                }
            });
        });

        // 初始化评论
        document.addEventListener('DOMContentLoaded', function() {
            var container = document.getElementById('utterances-container');
            if (container) {
                var script = createUtterancesScript();
                script.onload = handleUtterancesLoad;
                container.appendChild(script);
                observer.observe(document.body, { attributes: true });
            }
        });
    })();
</script>
<% } %>