<div class="container">
    <%# toc %>
    <%if(theme.post_toc_enable && toc(page.content).length!==0){%>
        <%- partial('_partial/toc') %>
    <%}%>

    <%# article %>
    <article class="post-wrap">
        <header class="post-header">
            <%# 面包屑导航 %>
            <%- partial('_partial/breadcrumb') %>
            <h1 class="post-title"><%= page.title %></h1>
            <%
function estimateReadingTime(content) {
    if (!content) return 1;
    // 移除 HTML 标签
    var text = content.replace(/<[^>]*>/g, '');
    // 中文字符数
    var chineseChars = (text.match(/[一-龥]/g) || []).length;
    // 英文单词数
    var englishWords = (text.match(/[a-zA-Z]+/g) || []).length;
    // 计算分钟数：中文部分 / 400 + 英文部分 / 200
    var minutes = Math.ceil(chineseChars / 400 + englishWords / 200);
    return minutes < 1 ? 1 : minutes;
}
var readingTime = estimateReadingTime(page.content);
%>
            <% if(theme.post_meta_enable){ %>
                <div class="post-meta">
                    <% if(theme.post_author_enable && config.author){ %>
                        Author: <a itemprop="author" rel="author" href="/"><%- config.author %></a>
                    <% } %>

                    <% if(page.date && theme.post_date_enable){ %>
                        <span class="post-time">
                        Date: <a href="#"><%- date(page.date, theme.date_format)  %>&nbsp;&nbsp;<%- time(page.date, theme.time_format)%></a>
                        </span>
                    <% } %>
                    <span class="post-reading-time">
                        Read: <a href="#"><%- readingTime %> min</a>
                    </span>
                    <% if(page.categories.length!==0 && theme.post_category_enable){ %>
                        <span class="post-category">
                    Category:
                            <% page.categories.forEach(item=>{ %>
                                <a href="<%- url_for(item.path) %>"><%- item.name %></a>
                            <% }) %>
                        </span>
                    <% } %>
                </div>
            <% } %>
        </header>

        <div class="post-content">
            <%- page.content %>
        </div>

        <% if(theme.post_copyright_enable){ %>
            <section class="post-copyright">
                <% if(theme.post_copyright_author_enable){ %>
                    <p class="copyright-item">
                        <span>Author:</span>
                        <span><%- config.author %></span>
                    </p>
                <% } %>
                <% if(theme.post_copyright_permalink_enable){ %>
                    <p class="copyright-item">
                        <span>Permalink:</span>
                        <span><a href="<%- page.permalink %>"><%- page.permalink %></a></span>
                    </p>
                <% } %>
                <% if(theme.post_copyright_license_enable){ %>
                    <p class="copyright-item">
                        <span>License:</span>
                        <span><%- theme.post_copyright_license_text %></span>
                    </p>
                <% } %>
                <% if(theme.post_copyright_slogan_enable){ %>
                     <p class="copyright-item">
                         <span>Slogan:</span>
                         <span><%- theme.post_copyright_slogan_text %></span>
                     </p>
                <% } %>

            </section>
        <% } %>
        <section class="post-tags">
            <div>
                <span>Tag(s):</span>
                <span class="tag">
                    <% if(page.tags.length!==0){%>
                    <% page.tags.forEach(item=>{ %>
                        <a href="<%- url_for(item.path) %>"># <%- item.name %></a>
                    <% }) %>
                        <% } %>
                </span>
                <%# 收藏按钮 %>
                <button class="post-bookmark" title="收藏文章">
                    <span class="bookmark-icon">♡</span>
                    <span class="bookmark-text">收藏</span>
                </button>
            </div>
            <div>
                <a href="javascript:window.history.back();">back</a>
                <span>· </span>
                <a href="<%- config.root %>">home</a>
            </div>
        </section>
        <%# 公众号引导模块 %>
        <section class="post-wechat-guide">
            <div class="wechat-guide-content">
                <div class="wechat-guide-icon">&#127760;</div>
                <div class="wechat-guide-text">
                    <p class="wechat-guide-title">关注公众号「程序猿视界」</p>
                    <p class="wechat-guide-desc">第一时间获取 AI 科技资讯、技术教程与精选资源</p>
                </div>
                <a href="/wechat" class="wechat-guide-btn" title="了解更多">关注</a>
            </div>
        </section>
        <%# Social Share %>
        <section class="post-share">
            <div class="share-buttons">
                <span>Share:</span>
                <a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(page.permalink) %>&text=<%= encodeURIComponent(page.title) %>" target="_blank" rel="noopener noreferrer" class="share-btn twitter">Twitter</a>
                <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(page.permalink) %>" target="_blank" rel="noopener noreferrer" class="share-btn facebook">Facebook</a>
                <a href="https://www.linkedin.com/shareArticle?mini=true&url=<%= encodeURIComponent(page.permalink) %>&title=<%= encodeURIComponent(page.title) %>" target="_blank" rel="noopener noreferrer" class="share-btn linkedin">LinkedIn</a>
                <a href="mailto:?subject=<%= encodeURIComponent(page.title) %>&body=<%= encodeURIComponent(page.permalink) %>" class="share-btn email">Email</a>
                <%# 微信分享 - 唤起微信扫一扫分享 %>
                <a href="javascript:;" class="share-btn wechat" onclick="showWechatShare()" title="微信分享">微信</a>
                <%# 微博分享 %>
                <a href="https://service.weibo.com/share/share.php?url=<%= encodeURIComponent(page.permalink) %>&title=<%= encodeURIComponent(page.title) %>" target="_blank" rel="noopener noreferrer" class="share-btn weibo" title="微博分享">微博</a>
                <%# Telegram 分享 %>
                <a href="https://t.me/share/url?url=<%= encodeURIComponent(page.permalink) %>&text=<%= encodeURIComponent(page.title) %>" target="_blank" rel="noopener noreferrer" class="share-btn telegram" title="Telegram 分享">Telegram</a>
                <%# 二维码分享 %>
                <a href="javascript:;" class="share-btn qrcode" onclick="showQRCode()" title="生成二维码">二维码</a>
            </div>
        </section>
        <%# 微信分享弹窗 %>
        <div id="wechat-share-modal" class="share-modal">
            <div class="share-modal-content">
                <span class="share-modal-close" onclick="closeWechatShare()">&times;</span>
                <h3>微信分享</h3>
                <p class="share-modal-tip">点击复制链接，在微信中粘贴分享</p>
                <div class="share-link-box">
                    <input type="text" id="share-link-input" value="<%= page.permalink %>" readonly>
                    <button onclick="copyShareLink()">复制</button>
                </div>
                <p class="share-modal-note">长按链接复制 → 打开微信 → 粘贴发送给朋友/朋友圈</p>
            </div>
        </div>
        <%# 二维码弹窗 %>
        <div id="qrcode-modal" class="share-modal">
            <div class="share-modal-content qrcode-modal-content">
                <span class="share-modal-close" onclick="closeQRCode()">&times;</span>
                <h3>扫描二维码分享</h3>
                <div id="qrcode-container"></div>
                <p class="qrcode-tip">使用微信扫码</p>
            </div>
        </div>
        <%# 相关文章推荐模块 %>
        <%
        // 生成相关文章（基于标签和分类匹配）
        var relatedPosts = [];
        var currentPostId = page.id || page.path;
        var allPosts = site.posts.toArray();

        if (allPosts.length > 1) {
            var currentTags = (page.tags || []).map(function(t) { return t.name || t; });
            var currentCats = (page.categories || []).map(function(c) { return c.name || c; });

            var scored = allPosts.filter(function(p) {
                return (p.id || p.path) !== currentPostId;
            }).map(function(p) {
                var score = 0;
                var postTags = (p.tags || []).map(function(t) { return t.name || t; });
                var postCats = (p.categories || []).map(function(c) { return c.name || c; });

                // 标签匹配
                currentTags.forEach(function(tag) {
                    if (postTags.indexOf(tag) !== -1) score += 3;
                });
                // 分类匹配
                currentCats.forEach(function(cat) {
                    if (postCats.indexOf(cat) !== -1) score += 2;
                });

                return { post: p, score: score };
            });

            scored.sort(function(a, b) { return b.score - a.score; });
            relatedPosts = scored.slice(0, 5).filter(function(item) { return item.score > 0; }).map(function(item) { return item.post; });
        }
        %>
        <% if(relatedPosts.length > 0){ %>
        <section class="related-posts">
            <h3 class="related-title">相关文章</h3>
            <ul class="related-list">
                <% relatedPosts.forEach(function(post){ %>
                <li class="related-item">
                    <a href="<%- url_for(post.path) %>">
                        <% if(post.cover){ %>
                        <span class="related-thumb" style="background-image: url(<%= post.cover %>)"></span>
                        <% } %>
                        <span class="related-info">
                            <span class="related-post-title"><%= post.title %></span>
                            <span class="related-date"><%- date(post.date, 'YYYY-MM-DD') %></span>
                        </span>
                    </a>
                </li>
                <% }); %>
            </ul>
        </section>
        <% } %>
        <section class="post-nav">
            <% if(post.prev){ %>
                <a class="prev" rel="prev" href="<%- url_for(post.prev.path)%>"><%- post.prev.title%></a>
            <% } %>
            <% if(post.next){ %>
            <a class="next" rel="next" href="<%- url_for(post.next.path)%>"><%- post.next.title%></a>
            <% } %>
        </section>

        <%# 引入评论组件 %>
        <%- partial('_partial/comments') %>

    </article>
</div>

<%# 阅读历史侧边栏 %>
<aside class="reading-history">
    <div class="history-toggle" title="阅读历史">
        <span class="history-icon">🕐</span>
    </div>
    <div class="history-panel">
        <div class="history-header">
            <span>阅读历史</span>
            <span class="history-count">0</span>
        </div>
        <span class="history-close">×</span>
        <ul class="history-list"></ul>
        <div class="history-empty" style="display: none;">暂无阅读记录</div>
    </div>
</aside>

<%# 分享功能 JavaScript %>
<script>
function showWechatShare() {
    document.getElementById('wechat-share-modal').style.display = 'flex';
}
function closeWechatShare() {
    document.getElementById('wechat-share-modal').style.display = 'none';
}
function copyShareLink() {
    var input = document.getElementById('share-link-input');
    input.select();
    document.execCommand('copy');
    alert('链接已复制！');
}
function showQRCode() {
    var modal = document.getElementById('qrcode-modal');
    var container = document.getElementById('qrcode-container');
    modal.style.display = 'flex';
    // 生成二维码
    if (typeof QRCode !== 'undefined') {
        container.innerHTML = '';
        var url = '<%= page.permalink %>';
        new QRCode(container, {
            text: url,
            width: 200,
            height: 200,
            colorDark: '#333333',
            colorLight: '#ffffff',
            correctLevel: QRCode.CorrectLevel.M
        });
    }
}
function closeQRCode() {
    document.getElementById('qrcode-modal').style.display = 'none';
}
// 点击模态框外部关闭
document.addEventListener('click', function(e) {
    var wechatModal = document.getElementById('wechat-share-modal');
    var qrcodeModal = document.getElementById('qrcode-modal');
    if (e.target === wechatModal) closeWechatShare();
    if (e.target === qrcodeModal) closeQRCode();
});

// ============================================================
// GA4 用户增长分析追踪代码 v2.13
// ============================================================
// T35.1 用户漏斗分析：首页→文章点击→阅读完成→深度互动
// T35.2 内容效果分析：阅读时长、完读率、跳出率
// T35.3 增长实验设计：A/B 测试框架
// ============================================================
(function(){
    'use strict';

    // ==================== 文章基础信息 ====================
    var articleInfo = {
        article_id: '<%= page.title %>',
        article_slug: '<%= page.slug %>',
        article_category: '<% if(page.categories && page.categories.length > 0) { %><%= page.categories.data[0] ? page.categories.data[0].name : page.categories[0].name %><% } else { %>未分类<% } %>',
        article_tags: '<% if(page.tags && page.tags.length > 0) { %><%= page.tags.map(function(t){ return t.name || t; }).join(",") %><% } else { %>无<% } %>',
        author: '<%= config.author %>',
        publish_date: '<% if(page.date){ %><%= date(page.date, "YYYY-MM-DD") %><% } else { %>未知<% } %>',
        reading_time: '<%= readingTime %>'
    };

    // 获取 URL 参数（用于 A/B 测试）
    function getUrlParam(name) {
        var params = new URLSearchParams(window.location.search);
        return params.get(name);
    }

    // ==================== A/B 测试框架 (T35.3) ====================
    var abTest = {
        // 从 URL 或 localStorage 获取实验组别
        getVariant: function(experimentId) {
            // 优先从 URL 参数获取
            var urlVariant = getUrlParam('v');
            if (urlVariant) {
                localStorage.setItem('ab_' + experimentId, urlVariant);
                return urlVariant;
            }
            // 从 localStorage 获取
            var stored = localStorage.getItem('ab_' + experimentId);
            if (stored) return stored;
            // 随机分配 (50/50)
            var variant = Math.random() < 0.5 ? 'A' : 'B';
            localStorage.setItem('ab_' + experimentId, variant);
            return variant;
        },
        // 追踪实验曝光
        trackExposure: function(experimentId, experimentName) {
            var variant = this.getVariant(experimentId);
            if (typeof gtag !== 'undefined') {
                gtag('event', 'ab_test_exposure', {
                    experiment_id: experimentId,
                    experiment_name: experimentName,
                    variant: variant
                });
            }
        },
        // 追踪实验转化
        trackConversion: function(experimentId, eventName, eventData) {
            var variant = this.getVariant(experimentId);
            if (typeof gtag !== 'undefined') {
                gtag('event', eventName, {
                    experiment_id: experimentId,
                    variant: variant,
                    ...eventData
                });
            }
        }
    };

    // T35.3: 标题实验追踪（示例实验）
    abTest.trackExposure('exp_title_style', 'article_title_style');

    // ==================== 用户漏斗追踪 (T35.1) ====================
    var funnel = {
        steps: {
            STEP1_HOMEPAGE_VIEW: 'homepage_view',
            STEP2_ARTICLE_CLICK: 'article_click',
            STEP3_ARTICLE_READ: 'article_read',
            STEP4_DEEP_ENGAGEMENT: 'deep_engagement'
        },
        // 追踪漏斗阶段
        trackStep: function(stepName, stepNumber, extraData) {
            if (typeof gtag !== 'undefined') {
                gtag('event', 'funnel_step', {
                    step: stepName,
                    step_number: stepNumber,
                    article_id: articleInfo.article_id,
                    article_category: articleInfo.article_category,
                    ...extraData
                });
            }
        }
    };

    // T35.1: 漏斗 Step 3 - 文章阅读开始
    funnel.trackStep(funnel.steps.STEP3_ARTICLE_READ, 3, {read_status: 'start'});

    // ==================== 内容效果分析 (T35.2) ====================
    var contentAnalytics = {
        // 滚动深度追踪状态
        scrollState: {
            hasTracked25: false,
            hasTracked50: false,
            hasTracked75: false,
            hasTracked90: false,
            maxScrollDepth: 0
        },
        // 阅读时长追踪
        readingTimer: {
            startTime: Date.now(),
            visibleTime: 0,
            lastVisibleTime: Date.now(),
            isVisible: true
        },
        // 追踪滚动深度
        trackScrollDepth: function() {
            var scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            var scrollTop = document.documentElement.scrollTop || document.body.scrollTop;
            var scrollPercent = scrollHeight > 0 ? Math.round((scrollTop / scrollHeight) * 100) : 0;

            // 更新最大滚动深度
            if (scrollPercent > this.scrollState.maxScrollDepth) {
                this.scrollState.maxScrollDepth = scrollPercent;
            }

            // 分阶段追踪（25%, 50%, 75%, 90%）
            var thresholds = [
                { percent: 25, tracked: 'hasTracked25', event: 'scroll_depth_25' },
                { percent: 50, tracked: 'hasTracked50', event: 'scroll_depth_50' },
                { percent: 75, tracked: 'hasTracked75', event: 'scroll_depth_75' },
                { percent: 90, tracked: 'hasTracked90', event: 'scroll_depth_90' }
            ];

            var self = this;
            thresholds.forEach(function(t) {
                if (scrollPercent >= t.percent && !self.scrollState[t.tracked]) {
                    self.scrollState[t.tracked] = true;
                    if (typeof gtag !== 'undefined') {
                        gtag('event', t.event, {
                            article_id: articleInfo.article_id,
                            article_category: articleInfo.article_category,
                            scroll_depth: t.percent,
                            max_scroll_depth: self.scrollState.maxScrollDepth
                        });
                    }
                }
            });

            // T35.1: 追踪漏斗 Step 4 - 深度互动（滚动 > 75%）
            if (scrollPercent >= 75 && !window.__deepEngagementTracked) {
                window.__deepEngagementTracked = true;
                funnel.trackStep(funnel.steps.STEP4_DEEP_ENGAGEMENT, 4, {
                    scroll_depth: scrollPercent,
                    engagement_type: 'scroll_75'
                });
            }
        },
        // 追踪阅读时长
        trackReadingTime: function() {
            var now = Date.now();
            var timer = this.readingTimer;

            if (timer.isVisible) {
                timer.visibleTime += now - timer.lastVisibleTime;
            }
            timer.lastVisibleTime = now;

            // 每 30 秒发送一次阅读时长
            if (!this._lastReportTime) this._lastReportTime = timer.startTime;
            if (now - this._lastReportTime >= 30000) {
                this._lastReportTime = now;
                var totalTime = Math.round((now - timer.startTime) / 1000);
                var visibleSeconds = Math.round(timer.visibleTime / 1000);
                if (typeof gtag !== 'undefined') {
                    gtag('event', 'reading_time_update', {
                        article_id: articleInfo.article_id,
                        total_time_seconds: totalTime,
                        visible_time_seconds: visibleSeconds
                    });
                }
            }
        },
        // 初始化可见性监听
        initVisibilityListener: function() {
            var self = this;
            document.addEventListener('visibilitychange', function() {
                if (document.hidden) {
                    self.readingTimer.isVisible = false;
                } else {
                    self.readingTimer.lastVisibleTime = Date.now();
                    self.readingTimer.isVisible = true;
                }
            });
        },
        // 页面离开时发送最终数据
        trackPageLeave: function() {
            var timer = this.readingTimer;
            var now = Date.now();
            if (timer.isVisible) {
                timer.visibleTime += now - timer.lastVisibleTime;
            }
            var totalTime = Math.round((now - timer.startTime) / 1000);
            var visibleSeconds = Math.round(timer.visibleTime / 1000);
            var bounceDetected = totalTime < 10 && this.scrollState.maxScrollDepth < 30;

            if (typeof gtag !== 'undefined') {
                // T35.2: 跳出率追踪
                gtag('event', 'article_bounce', {
                    article_id: articleInfo.article_id,
                    article_category: articleInfo.article_category,
                    is_bounce: bounceDetected,
                    total_time_seconds: totalTime,
                    visible_time_seconds: visibleSeconds,
                    max_scroll_depth: this.scrollState.maxScrollDepth
                });

                // T35.2: 完读率追踪（滚动 > 90%）
                if (this.scrollState.maxScrollDepth >= 90) {
                    gtag('event', 'article_completed', {
                        article_id: articleInfo.article_id,
                        article_category: articleInfo.article_category,
                        total_time_seconds: totalTime,
                        visible_time_seconds: visibleSeconds
                    });
                }

                // T35.2: 阅读时长最终报告
                gtag('event', 'reading_time_final', {
                    article_id: articleInfo.article_id,
                    total_time_seconds: totalTime,
                    visible_time_seconds: visibleSeconds,
                    max_scroll_depth: this.scrollState.maxScrollDepth,
                    read_completion: this.scrollState.maxScrollDepth >= 90
                });
            }
        }
    };

    // 初始化内容分析
    contentAnalytics.initVisibilityListener();

    // 页面滚动监听
    window.addEventListener('scroll', function() {
        contentAnalytics.trackScrollDepth();
        contentAnalytics.trackReadingTime();
    });

    // 页面离开监听
    window.addEventListener('beforeunload', function() {
        contentAnalytics.trackPageLeave();
    });
    // 对于 SPA 或 History API 导航
    window.addEventListener('pagehide', function() {
        contentAnalytics.trackPageLeave();
    });

    // ==================== 分享事件追踪 ====================
    var shareButtons = document.querySelectorAll('.share-btn');
    shareButtons.forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            var method = 'other';
            var className = this.className || '';

            if (className.indexOf('twitter') !== -1) {
                method = 'twitter';
            } else if (className.indexOf('facebook') !== -1) {
                method = 'facebook';
            } else if (className.indexOf('linkedin') !== -1) {
                method = 'linkedin';
            } else if (className.indexOf('email') !== -1) {
                method = 'email';
            } else if (className.indexOf('wechat') !== -1) {
                method = 'wechat';
            } else if (className.indexOf('weibo') !== -1) {
                method = 'weibo';
            } else if (className.indexOf('telegram') !== -1) {
                method = 'telegram';
            } else if (className.indexOf('qrcode') !== -1) {
                method = 'qrcode';
            }

            if (typeof gtag !== 'undefined') {
                gtag('event', 'share', {
                    method: method,
                    content_type: 'article',
                    article_id: articleInfo.article_id,
                    article_category: articleInfo.article_category
                });

                // T35.3: 分享作为转化事件追踪
                abTest.trackConversion('exp_title_style', 'share_action', {
                    article_id: articleInfo.article_id,
                    share_method: method
                });
            }
        });
    });

    // ==================== 收藏按钮点击追踪 ====================
    var bookmarkBtn = document.querySelector('.post-bookmark');
    if (bookmarkBtn) {
        bookmarkBtn.addEventListener('click', function() {
            if (typeof gtag !== 'undefined') {
                gtag('event', 'bookmark_add', {
                    article_id: articleInfo.article_id,
                    article_category: articleInfo.article_category
                });
            }
        });
    }

    // ==================== 相关文章点击追踪 ====================
    var relatedLinks = document.querySelectorAll('.related-item a');
    relatedLinks.forEach(function(link) {
        link.addEventListener('click', function() {
            if (typeof gtag !== 'undefined') {
                gtag('event', 'related_article_click', {
                    from_article: articleInfo.article_id,
                    to_article: link.href,
                    click_position: 'related_section'
                });
            }
        });
    });

    // ==================== 初始页面浏览事件 ====================
    if (typeof gtag !== 'undefined') {
        gtag('event', 'article_view', {
            article_id: articleInfo.article_id,
            article_slug: articleInfo.article_slug,
            article_category: articleInfo.article_category,
            article_tags: articleInfo.article_tags,
            author: articleInfo.author,
            publish_date: articleInfo.publish_date,
            reading_time: parseInt(articleInfo.reading_time),
            content_type: 'article'
        });
    }

    // 暴露 abTest 对象到全局供外部实验使用
    window.__abTest = abTest;
    window.__funnel = funnel;
    window.__contentAnalytics = contentAnalytics;
})();
</script>
