.post-content
  code, pre
    line-height 1.7em
    padding 7px
    font-size 13px
    font-family Consolas, Monaco, Menlo, Consolas, monospace
  code
    line-height 1.7em
    padding 3px 5px
    border-radius 4px
    color $light-code-font-color
    background $light-code-background-color
    .dark-theme &
      color $dark-code-font-color
      background $dark-code-background-color
  
  h1,h2,h3,h4,h5  // title inline code block
    code
      font-size inherit        

  figure.highlight
    margin 1em 0
    overflow-x auto
    position relative
    &::-webkit-scrollbar
      width 6px
      height 6px
    &::-webkit-scrollbar-thumb
      width 6px
      background-color #eee
      border-radius 2px
    figcaption
      padding 0 0.5em
      text-align right
      font-size 13px
      span
        margin 0 0.5em
    table
      position relative
    table, tr, td
      margin 0
      padding 0
      border 0
      width 100%
      border-collapse collapse
    .code
      pre
        margin 0 10px

    // line number
    .gutter
      width 10px
      color #d0d0d0
      pre
        margin 0

    // 代码块复制按钮
    .copy-btn
      position absolute
      top 8px
      right 8px
      padding 4px 10px
      font-size 12px
      color #999
      background #f5f5f5
      border 1px solid #ddd
      border-radius 4px
      cursor pointer
      opacity 0
      transition opacity 0.2s
      z-index 10
      &:hover
        color #666
        background #eee
      &.copied
        color #fff
        background #4caf50
        border-color #4caf50

    figure.highlight:hover .copy-btn
      opacity 1

  .dark-theme &
    .copy-btn
      color #aaa
      background #2a2a2a
      border-color #444
      &:hover
        color #fff
        background #3a3a3a
      &.copied
        background #4caf50
        border-color #4caf50